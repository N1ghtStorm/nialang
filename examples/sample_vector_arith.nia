// Fixed-size vectors: component-wise + and - (same vector type on both sides).

vector Vec2 i32 [
    X,
    Y,
]

vector Vec3 i32 [
    X,
    Y,
    Z,
]

fn main() i32 {
    let u = Vec2 [X: 3, Y: 4];
    let v = Vec2 [X: 1, Y: 2];
    let sum2 = u + v;
    let diff2 = u - v;
    println(sum2);
    println(diff2);

    let a = Vec3 [X: 10, Y: 20, Z: 30];
    let b = Vec3 [X: 1, Y: 2, Z: 3];
    println(a + b);
    println(a - b);

    0
}
