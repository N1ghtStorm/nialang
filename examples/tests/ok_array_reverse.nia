fn main() i32 {
    let arr: [u8; 8] = [1, 2, 3, 4, 5, 6, 7, 8];
    let reversed: [u8; 8] = reverse_array(arr);
    println(reversed);
    0
}

fn reverse_array(arr: [u8; 8]) [u8; 8] {
    for i in 0..len(arr) {
        let temp: u8 = arr[i];
        arr[i] = arr[7 - i];
        arr[7 - i] = temp;
    }
    arr
}
