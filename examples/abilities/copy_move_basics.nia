// Abilities phase 1-3 sample:
// - `has copy, clone` on a struct,
// - copy values stay usable after assignment and by-value calls.

struct Point has copy, clone {
    x: i32,
    y: i32
}

fn score(p: Point) i32 {
    p.x * 10 + p.y
}

fn main() i32 {
    let a = Point { x: 2, y: 7 };
    let b = a;
    let total = score(a) + score(b);

    println(a);
    println(b);
    println(total);

    0
}
